{
  "name": "liver-cli",
  "version": "0.1.2",
  "description": "BAC tracking CLI",
  "type": "module",
  "bin": {
    "liver": "./bin/liver"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest run",
    "test:bands": "vitest run tests/bands",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "vendor:build": "cd vendor/ethanol-rs/crates/ethanol-rs-wasm && wasm-pack build --target nodejs --release --out-dir pkg && cp -r pkg/* ../../ethanol-rs-pkg/",
    "vendor:check": "node -e \"require('./vendor/ethanol-rs-pkg/ethanol_rs_wasm.js')\""
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chrono-node": "^2.7.6",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.0.0",
    "biome": "^0.3.3",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.1"
  }
}
