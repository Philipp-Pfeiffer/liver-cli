{
  "name": "liver-cli",
  "version": "0.1.2",
  "description": "BAC tracking CLI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "liver": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE-MIT",
    "README.md",
    "CHANGELOG.md",
    "docs/ADR-002.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chrono-node": "^2.7.6",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.0.0",
    "biome": "^0.3.3",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.1"
  }
}
